############################################
# Project_Sync（只保留目录结构，不提交交换文件）
############################################
Project_Sync/**
!Project_Sync/.gitkeep
!Project_Sync/01_Distribution/
!Project_Sync/01_Distribution/.gitkeep
!Project_Sync/02_Collection/
!Project_Sync/02_Collection/.gitkeep
!Project_Sync/archive/
!Project_Sync/archive/.gitkeep

############################################
# 任务包 / 结果包 / 同步标记
############################################
*.zip
*.done
*.flag
*.UPLOAD_DONE.flag

############################################
# 中心运行产物
############################################
center/raw_input/**
!center/raw_input/
!center/raw_input/.gitkeep

center/central_data_pool/**
center/central_result_pool/**
center/task_packages/**
!center/task_packages/
!center/task_packages/.gitkeep

center/received_packages/**
center/manifests/**
!center/manifests/
!center/manifests/.gitkeep

center/review/**
!center/review/
!center/review/.gitkeep

center/final_output/**
!center/final_output/
!center/final_output/.gitkeep

center/logs/**
!center/logs/.gitkeep

center/tmp/**
!center/tmp/.gitkeep

############################################
# 本地运行产物
############################################
local/local_workspace/**
!local/local_workspace/
!local/local_workspace/.gitkeep

local/logs/**
!local/logs/.gitkeep

local/tmp/**
!local/tmp/.gitkeep

############################################
# 根目录运行产物
############################################
logs/**
!logs/.gitkeep

tmp/**
!tmp/.gitkeep

############################################
# 数据与媒体文件（禁止提交真实数据）
############################################
*.png
*.jpg
*.jpeg
*.tif
*.tiff
*.bmp
*.nii
*.nii.gz
*.xlsx

# 允许示例模板
!docs/examples/*.xlsx
!configs/templates/*.xlsx

############################################
# Python / 环境
############################################
__pycache__/
*.pyc
*.pyo
*.pyd

.venv/
venv/
.env

############################################
# Label Studio / userscript / local_api 运行数据
############################################
local/label_studio/exports/**
local/label_studio/imports/**
local/label_studio/import_payloads/**
local/label_studio/data/**
local/label_studio/tmp/**

!local/label_studio/import_payloads/.gitkeep

local/userscript/tmp/**
local/local_api/tmp/**

############################################
# 其他
############################################
.DS_Store
Thumbs.db