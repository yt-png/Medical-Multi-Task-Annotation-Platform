# 根目录运行产物
# =========================
logs/**
!logs/.gitkeep
tmp/**
!tmp/.gitkeep

# =========================
# 数据文件（禁止提交真实数据）
# =========================
*.png
*.jpg
*.jpeg
*.tif
*.tiff
*.bmp
*.nii
*.nii.gz

# Excel（禁止真实数据，允许模板）
*.xlsx
!docs/examples/*.xlsx
!configs/templates/*.xlsx

# =========================
# Python / 环境
# =========================
__pycache__/
*.pyc
.venv/
venv/
.env

